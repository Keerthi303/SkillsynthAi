# =========================================================
# Skill Synth AI — Environment Variables
# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git.
# =========================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# --- AI Provider (Gemini) ---
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- GitHub (optional but recommended) ---
# Anonymous works but is rate-limited to 60 req/hr.
# Create a PAT (no scopes needed for public data) at:
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Database ---
# Default: SQLite at instance/app.db (zero setup)
# To use Postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///app.db

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chromadb

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=10
